# Auto detect text files and normalize to LF
* text=auto eol=lf

# Python
*.py text eol=lf

# Shell
*.sh text eol=lf

# Markdown
*.md text eol=lf

# YAML
*.yml text eol=lf
*.yaml text eol=lf

# Docker
Dockerfile text eol=lf
*.dockerfile text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary